# WordPress Plugin Distribution Ignore File
# This file specifies which files and directories should be excluded from the plugin distribution zip

# Development dependencies
/node_modules/

# Development configuration files (root-only)
/phpcs-report.xml
/.eslintrc
/webpack.config.js
/constants.php

# Dev config and documentation files excluded everywhere (never needed at runtime)
*.md
composer.lock
phpunit.xml
phpunit.xml.dist
phpcs.xml
phpcs.xml.dist
phpstan.neon
phpstan.neon.dist
package.json
package-lock.json
Makefile
.travis.yml
.scrutinizer.yml
Dockerfile
docker-compose.yml

# Version control and CI/CD
.git/
.github/
.gitignore

# IDE and editor files
.idea/
.vscode/
.claude/
.junie/
.windsurfrules/
.opencode/
.agents/
.mcp.json

# Test files
/tests/

# Build artifacts and cache
/lib/

# Source assets (compiled to build/)
/resources/
